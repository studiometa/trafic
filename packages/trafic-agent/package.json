{
  "name": "@studiometa/trafic-agent",
  "version": "0.1.18",
  "description": "Server agent for DDEV preview environments — auth, scale-to-zero, auto-start",
  "keywords": [
    "agent",
    "auth",
    "ddev",
    "scale-to-zero",
    "traefik"
  ],
  "license": "MIT",
  "author": "Studio Meta",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiometa/trafic",
    "directory": "packages/trafic-agent"
  },
  "bin": {
    "trafic-agent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsgo --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
